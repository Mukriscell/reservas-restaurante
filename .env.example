# ─── Firebase (Firestore) — base de datos en producción ─────────────────
#
# Opción A (recomendada): el JSON completo de la cuenta de servicio en una
# sola variable. En Firebase Console: Configuración del proyecto → Cuentas
# de servicio → Generar nueva clave privada. Pega el contenido del .json:
FIREBASE_SERVICE_ACCOUNT=

# Opción B: las tres piezas por separado (la clave privada con \n literales):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Sin ninguna de las dos opciones, la app guarda en data/reservas.json
# (solo para desarrollo local).
#
# Para probar con el emulador de Firestore en vez de un proyecto real:
# FIRESTORE_EMULATOR_HOST=localhost:8080

# ─── Acceso de administrador (/admin) ────────────────────────────────────
#
# Credenciales del login del panel. En desarrollo, si no las defines,
# el acceso es admin / mesalista. En producción son OBLIGATORIAS:
# sin ADMIN_PASSWORD el login queda deshabilitado.
ADMIN_USER=admin
ADMIN_PASSWORD=

# ─── Correo de confirmación (SMTP) ───────────────────────────────────────
#
# Sin estas variables la app funciona igual, pero no envía correos.
# Con Gmail: activa la verificación en 2 pasos y crea una "contraseña de
# aplicación" (https://myaccount.google.com/apppasswords); úsala en SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Remitente que ve el cliente (opcional, por defecto usa SMTP_USER):
# MAIL_FROM="MESALISTA <reservas@turestaurante.cl>"

# ─── URL pública de la app ───────────────────────────────────────────────
#
# Se usa para armar los enlaces de gestión que van en los correos.
# Si no la defines, se deduce de cada petición (suele bastar).
# APP_URL=https://mesalista.vercel.app
