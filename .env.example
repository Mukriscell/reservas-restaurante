# Credenciales de Firebase (Firestore) — modo producción.
#
# Opción A (recomendada): el JSON completo de la cuenta de servicio en una
# sola variable. En Firebase Console: Configuración del proyecto → Cuentas
# de servicio → Generar nueva clave privada. Pega el contenido del .json:
FIREBASE_SERVICE_ACCOUNT=

# Opción B: las tres piezas por separado (la clave privada con \n literales):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Sin ninguna de las dos opciones, la app guarda en data/reservas.json
# (solo para desarrollo local).
#
# Para probar con el emulador de Firestore en vez de un proyecto real:
# FIRESTORE_EMULATOR_HOST=localhost:8080
