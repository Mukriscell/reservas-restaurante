{
  "name": "porto-alegre-mesas",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Porto Alegre — App móvil (PWA) de consumo de mesas para garzones",
  "packageManager": "pnpm@9.1.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "start": "serve -s dist -l tcp://0.0.0.0:${PORT:-3000}"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "serve": "^14.2.4"
  },
  "devDependencies": {
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.5.4",
    "vite": "^6.0.0"
  }
}
